<?xml version="1.0" encoding="utf-8"?>
<widget id="mendix.chartjsarea.ChartJSArea" pluginWidget="true" needsEntityContext="true" offlineCapable="true"
        supportedPlatform="Web"
        xmlns="http://www.mendix.com/widget/1.0/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>Chart JSArea</name>
    <description>My widget description</description>
    <icon>
        
    </icon>
    <properties>
        
     <propertyGroup caption="General">

            <property key="seriesList" type="object" isList="true">
                <caption>Series</caption>
                <description />

                <properties>
                    <propertyGroup caption="Series Configuration">

                        <!-- ✅ Each series has its own datasource -->
                        <property key="dataSource" type="datasource" isList="true">
                            <caption>Data source</caption>
                            <description />
                        </property>

                        <property key="labelAttribute" type="attribute" dataSource="dataSource">
                            <caption>Label (X-axis)</caption>
                            <description>Select the attribute used for X-axis labels</description>
                            <attributeTypes>
                                <attributeType name="String"/>
                            </attributeTypes>
                        </property>

                        <property key="valueAttribute" type="attribute" dataSource="dataSource">
                            <caption>Value (Y-axis)</caption>
                            <description>Select the attribute used for Y-axis values.</description>
                            <attributeTypes>
                                <attributeType name="Integer"/>
                                <attributeType name="Decimal"/>
                                <attributeType name="Long"/>
                                <attributeType name="String"/>
                                <attributeType name="Boolean" />
                                <attributeType name="DateTime" />
                                <attributeType name="HashString" />
                            </attributeTypes>
                        </property>
                         <property key="seriesLabel" type="attribute" required="false">
                            <caption>Series Label</caption>
                            <description>Select the attribute used as the dataset label shown in the chart legend.</description>
                            <attributeTypes>
                                <attributeType name="String"/>
                            </attributeTypes>
                        </property>

                        <!-- <property key="seriesLabel" type="string">
                            <caption>Series Label</caption>
                            <description />
                        </property> -->
                        <property key="colorKey" type="attribute" required="false">
                            <caption>Line(Area) Color (Hex) </caption>
                            <description>Line(Area) Color (Hex) in comma separated values . Eg. #4dc9f6,#f67019</description>
                            <attributeTypes>
                                <attributeType name="String"/>
                            </attributeTypes>
                        </property>

                        <!-- <property key="colorKey" type="string">
                            <caption>Bar Color (Hex)</caption>
                            <description />
                        </property> -->

                    </propertyGroup>
                 
                </properties>
            </property>

            

        </propertyGroup>

<propertyGroup caption="Configuration">

                <!-- <property key="chartTitle" type="string">
                <caption>Chart Title</caption>
                <description>Chart heading</description>
            </property> -->
            <property key="chartTitle" type="attribute" required="false">
                            <caption>Chart Title </caption>
                            <description>Title of the chart</description>
                            <attributeTypes>
                                <attributeType name="String"/>
                            </attributeTypes>
                        </property>

            <!-- <property key="height" type="integer" defaultValue="350">
                <caption>Chart Height</caption>
                <description>Height in pixels</description>
            </property> -->

             <property key="height" type="attribute" required="false">
                            <caption>Chart Height </caption>
                            <description>Height in pixels</description>
                            <attributeTypes>
                                <attributeType name="Integer"/>
                            </attributeTypes>
                        </property>

            <!-- <property key="showLegend" type="boolean" defaultValue="true">
                <caption>Show Legend</caption>
                <description>Chart heading</description>
            </property> -->
            <property key="showLegend" type="attribute" required="false">
                            <caption>Show Legend </caption>
                            <description>Whether to display the chart legend</description>
                            <attributeTypes>
                                <attributeType name="Boolean"/>
                            </attributeTypes>
                        </property>
            

            <!-- <property key="showGrid" type="boolean" defaultValue="true">
                <caption>Show Grid</caption>
                <description>Chart heading</description>
            </property> -->

            <property key="showGrid" type="attribute" required="false">
                            <caption>Show Grid </caption>
                            <description>Whether to display the chart grid</description>
                            <attributeTypes>
                                <attributeType name="Boolean"/>
                            </attributeTypes>
                        </property>

            <!-- <property key="stacked" type="boolean" defaultValue="false">
                <caption>Stacked Bars</caption>
                <description>Chart heading</description>
            </property> -->

            <!-- <property key="stacked" type="attribute" required="false">
                            <caption>Stacked Bars </caption>
                            <description>Whether to display stacked bars</description>
                            <attributeTypes>
                                <attributeType name="Boolean"/>
                            </attributeTypes>
                        </property> -->

            <!-- <property key="horizontal" type="boolean" defaultValue="false">
                <caption>Horizontal Chart</caption>
                <description>Chart heading</description>
            </property> -->

             <!-- <property key="horizontal" type="attribute" required="false">
                            <caption>Horizontal Chart </caption>
                            <description>Whether to display the chart horizontally</description>
                            <attributeTypes>
                                <attributeType name="Boolean"/>
                            </attributeTypes>
                        </property> -->

            <!-- <property key="enableAnimation" type="boolean" defaultValue="true">
                <caption>Enable Animation</caption>
                <description>Chart heading</description>
            </property> -->

            <property key="enableAnimation" type="attribute" required="false">
                            <caption>Enable Animation </caption>
                            <description>Whether to enable chart animations</description>
                            <attributeTypes>
                                <attributeType name="Boolean"/>
                            </attributeTypes>
                        </property>
                         <property key="showValueOnTop" type="attribute" required="false">
                            <caption>Show Values on Top </caption>
                            <description>Whether to display values on top of the bars</description>
                            <attributeTypes>
                                <attributeType name="Boolean"/>
                            </attributeTypes>
                        </property>

                         <property key="ShowExportKey" type="attribute" required="false">
                            <caption>Show Export Button </caption>
                            <description>Whether to display the export button</description>
                            <attributeTypes>
                                <attributeType name="Boolean"/>
                            </attributeTypes>
                            </property>

                            <property key="ShowZoomKey" type="attribute" required="false">
                            <caption>Show Zoom Button </caption>
                            <description>Whether to display the zoom button</description>
                            <attributeTypes>
                                <attributeType name="Boolean"/>
                            </attributeTypes>
                            </property>

                          <property key="onClickValueKey" type="attribute" required="false">
                            <caption>on click value </caption>
                            <description>set the onclick value attribute. The attribute should be of type string with unlimited characters. The sample json value:Label=jan; Value=5; Dataset=Series 2;</description>
                            <attributeTypes>
                                <attributeType name="String"/>
                            </attributeTypes>
                        </property>
                       

                 </propertyGroup>
                 <propertyGroup caption="Events">
            <property key="onClickAction" type="action" required="false">
                <caption>On click action</caption>
                <description>Action to trigger when button / label is clicked</description>
            </property>
        </propertyGroup>

<propertyGroup caption="Visibility">
                <systemProperty key="Visibility"/>
            </propertyGroup>

    </properties>
</widget>
